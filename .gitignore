# ── dependencies ──
node_modules/

# ── build output (regenerated; Liara rebuilds on deploy) ──
dist/
dev-dist/
*.tsbuildinfo

# ── logs & caches ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vite/
.cache/

# ── local env / secrets (keep *.example committed) ──
.env
.env.local
.env.*.local

# ── graphify knowledge-graph output (regenerable, can be large) ──
graphify-out/
.graphify/

# ── Claude Code: keep shared config, ignore personal/local ──
.claude/settings.local.json

# ── editor / OS ──
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp

# NOTE: server/ has its own .gitignore (ignores vendor/, .env, *.sqlite, etc.)
