# ---------------------------------------------------------------------------
# Production env template for the Laravel API on Liara (app: journal-api).
# Set these in the Liara panel (journal-api → تنظیمات → متغیرها) or via:
#   liara env set KEY=value --app journal-api
# Do NOT put these in liara.json's "envs" block — that block REPLACES all
# panel/CLI-set variables on every deploy and would wipe APP_KEY + DB creds.
# ---------------------------------------------------------------------------

APP_NAME="Trade Journal"
APP_ENV=production
# Generate locally:  php artisan key:generate --show   → paste the base64:... value
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY
APP_DEBUG=false
APP_URL=https://letstrade-api.liara.run

# Locks CORS to the PWA origin (config/cors.php reads this; comma-separate for more).
FRONTEND_URL=https://letstrade.liara.run

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database: managed MySQL created in the Liara console ---
# The filesystem is ephemeral, so SQLite would be wiped on restart/redeploy.
# Private network (recommended): use the DB identifier as host + port 3306.
# Public endpoint: use the *.liara.cloud host + the RANDOM port shown in the panel
# (do NOT assume 3306 publicly). Copy DB_DATABASE / DB_PASSWORD exactly.
DB_CONNECTION=mysql
DB_HOST=REPLACE_WITH_DB_HOST
DB_PORT=REPLACE_WITH_DB_PORT
DB_DATABASE=REPLACE_WITH_DB_NAME
DB_USERNAME=root
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Backed by MySQL via migrations — no local disk needed.
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Mail ---
# 'log' = verification codes are written to the log, NOT emailed. Keep the admin
# "require email verification" toggle OFF until you switch to real SMTP below.
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.your-provider.com
#   MAIL_PORT=587
#   MAIL_USERNAME=your-smtp-user
#   MAIL_PASSWORD=your-smtp-password
#   MAIL_SCHEME=tls
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@journal.liara.run"
MAIL_FROM_NAME="${APP_NAME}"
